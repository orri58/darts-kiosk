# Darts Kiosk System
# Environment configuration for Docker deployment

# ==== MODE ====
# MASTER = Central admin panel + board registry (run on one machine)
# AGENT = Kiosk + local staff page (run on each board PC)
MODE=MASTER

# ==== BOARD ID ====
# Unique identifier for this board (only relevant for AGENT mode)
BOARD_ID=BOARD-1

# ==== SECURITY ====
# Change these in production!
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
AGENT_SECRET=your-agent-communication-secret-change-this

# ==== DATABASE ====
# SQLite (default) - path inside container
DATABASE_URL=sqlite+aiosqlite:///data/db.sqlite
SYNC_DATABASE_URL=sqlite:///data/db.sqlite
DATA_DIR=/data

# For PostgreSQL migration (optional):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost/darts_kiosk
# SYNC_DATABASE_URL=postgresql://user:password@localhost/darts_kiosk

# ==== NETWORK ====
# CORS origins (comma separated) - use * for development
CORS_ORIGINS=*

# Master URL (for agents to connect)
MASTER_URL=http://192.168.1.100:8001

# ==== AUTODARTS ====
# Autodarts web interface URL
AUTODARTS_URL=https://play.autodarts.io

# Set to 'true' to use mock integration (for testing)
AUTODARTS_MOCK=false

# ==== OPTIONAL: NGINX ====
# If using nginx reverse proxy
# SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
# SSL_KEY_PATH=/etc/nginx/ssl/key.pem
