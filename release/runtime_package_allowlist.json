{
  "schema_version": 1,
  "intent": "Draft allowlist for future runtime-only board-device payloads. This is advisory and does not change the current release flow.",
  "target_profile": "windows-board-runtime",
  "allowed_roots": [
    "app/",
    "data/",
    "config/"
  ],
  "required_paths": [
    "app/backend/",
    "app/frontend/build/",
    "app/agent/",
    "app/bin/",
    "config/backend.env.example",
    "config/frontend.env.example",
    "config/runtime_retention.env.example",
    "config/VERSION"
  ],
  "allow": [
    "app/",
    "app/backend/",
    "app/backend/*.py",
    "app/backend/**/*.py",
    "app/backend/requirements.txt",
    "app/backend/integrations/",
    "app/backend/models/",
    "app/backend/routers/",
    "app/backend/services/",
    "app/frontend/",
    "app/frontend/build/",
    "app/frontend/build/**",
    "app/agent/",
    "app/agent/*.py",
    "app/agent/**/*.py",
    "app/agent/*.bat",
    "app/agent/*.vbs",
    "app/agent/*.md",
    "app/agent/requirements.txt",
    "app/bin/",
    "app/bin/*.bat",
    "app/bin/*.py",
    "app/bin/*.md",
    "app/bin/VERSION",
    "app/bin/runtime_maintenance.py",
    "config/",
    "config/*.env.example",
    "config/VERSION",
    "data/",
    "data/db/",
    "data/logs/",
    "data/backups/",
    "data/app_backups/",
    "data/downloads/",
    "data/assets/",
    "data/chrome_profile/",
    "data/kiosk_ui_profile/"
  ],
  "exclude_globs": [
    "**/.git/**",
    "**/.pytest_cache/**",
    "**/__pycache__/**",
    "**/*.pyc",
    "**/tests/**",
    "**/node_modules/**",
    "**/frontend/src/**",
    "**/frontend/public/**",
    "**/central_server/**",
    "**/kiosk_experimental/**",
    "**/docs/**",
    "**/*.sqlite*",
    "**/.env",
    "**/memory/**",
    "**/test_reports/**",
    "**/.emergent/**"
  ],
  "retention": {
    "update_payloads": "keep current + previous rollback only",
    "app_backups": "keep last 2 successful backups",
    "logs": "rotate by size and cap retained files",
    "support_bundles": "auto-expire after operator-defined short TTL"
  },
  "notes": [
    "Current release bundles are still repo-shaped and intentionally include more than this draft allowlist permits.",
    "A later packaging pass should map current root-level Windows scripts into app/bin/ and move env examples + VERSION into config/.",
    "Data directories stay writable and are preserved across updates; app/ should become replaceable as a unit."
  ]
}
